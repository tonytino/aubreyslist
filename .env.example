# Neon serverless Postgres connection string. (Required)
# Get one at https://neon.tech → New Project → Connection Details.
# This template uses Neon's HTTP driver (drizzle-orm/neon-http), so the pooled
# vs. direct endpoint doesn't matter — either connection string works. (The
# -pooler endpoint is for the WebSocket `Pool` driver, which this template
# doesn't use.)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Google OAuth client ID + secret (safe:human, provisioned by a human).
# Google Cloud Console → APIs & Services → Credentials → Create Credentials →
# OAuth client ID (Web application). See docs/setup/provisioning.md (#14) and
# ADR-006. Stay optional in app/env.ts (CI lacks them); the auth routes (#15)
# guard at point of use and error clearly if a sign-in is attempted unset.
# Authorized redirect URI must be: <origin>/api/auth/callback/google
#   (local: http://localhost:3000/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Places server-side API key (safe:human, provisioned by a human).
# Same Google Cloud project → Enable the Places API → Credentials → Create
# Credentials → API key, then restrict it to the Places API. Server-side only —
# never expose to the browser. See docs/setup/provisioning.md (#21) and ADR-008.
# Optional in app/env.ts until the Places provider issue (#22) requires it.
GOOGLE_PLACES_API_KEY=

# Session signing secret (safe:human, provisioned by a human).
# Generate any long random string: `openssl rand -hex 32`. See
# docs/setup/provisioning.md (#14) and ADR-006. Optional in app/env.ts until
# the auth issue (#15) requires it.
SESSION_SECRET=
