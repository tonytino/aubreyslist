{
  "name": "aubreyslist",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "check": "biome check --write .",
    "preflight": "biome check . && tsc --noEmit && vitest run",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "changelog:preview": "node scripts/changelog.mjs preview",
    "changelog:check": "node scripts/changelog.mjs check",
    "changelog:release": "node scripts/changelog.mjs release",
    "typecheck": "tsc --noEmit",
    "knip": "knip --include dependencies,unlisted",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "test:mutation": "stryker run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed-admin": "node --experimental-strip-types --import ./scripts/register-aliases.mjs ./scripts/seed-admin.ts",
    "postinstall": "tsr generate",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.67.0",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "iron-webcrypto": "^1.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@playwright/test": "^1.50.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/nitro-v2-vite-plugin": "^1.155.0",
    "@tanstack/router-cli": "^1.167.0",
    "@tanstack/start-storage-context": "^1.167.15",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.30.0",
    "jsdom": "^26.0.0",
    "knip": "^6.20.0",
    "lefthook": "^1.11.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "shell-quote": "^1.8.4",
      "h3": "^1.15.9",
      "nitropack": "^2.13.4",
      "tar": "^7.5.16",
      "ws": "^8.21.0",
      "brace-expansion@5": "5.0.6",
      "@babel/core": "^7.29.6",
      "qs": "^6.15.2",
      "diff": "^8.0.3"
    }
  },
  "description": "A web app built from the construct template."
}
